# Database Configuration
DATABASE_URL="mysql://username:password@localhost:3306/solar_analyzer"

# Application Environment
NODE_ENV=development

# Ollama Configuration (for local LLM inference)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen2.5:14b
OLLAMA_VISION_MODEL=llava:13b

# Mapbox Configuration (for satellite imagery)
# Get your free token at https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# OAuth Configuration (optional - only needed for production deployment)
# VITE_APP_ID=your_app_id
# OAUTH_SERVER_URL=https://api.manus.im
# VITE_OAUTH_PORTAL_URL=https://portal.manus.im
# JWT_SECRET=your_jwt_secret

# Manus Built-in APIs (optional - fallback if Ollama not available)
# BUILT_IN_FORGE_API_URL=https://api.manus.im
# BUILT_IN_FORGE_API_KEY=your_api_key
# VITE_FRONTEND_FORGE_API_KEY=your_frontend_api_key
# VITE_FRONTEND_FORGE_API_URL=https://api.manus.im

# Owner Information (optional)
# OWNER_OPEN_ID=your_open_id
# OWNER_NAME=Your Name

# Analytics (optional)
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=your_website_id

# Application Branding (optional)
# VITE_APP_TITLE=Solar Farm Performance Analyzer
# VITE_APP_LOGO=/mce-logo.png
